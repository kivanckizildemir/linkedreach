# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Supabase (frontend — Vite build)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Redis (BullMQ queues + account locks) ─────────────────────────────────────
# Railway: use the Railway Redis plugin — copy the REDIS_URL it provides
REDIS_URL=redis://localhost:6379

# ── Claude API ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Proxy ─────────────────────────────────────────────────────────────────────
# Static residential proxy for LinkedIn automation (same IP per account).
# Format: http://user:pass@host:port
PROXY_HOST=
PROXY_PORT=
PROXY_USERNAME=
PROXY_PASSWORD=
# Set to 'true' to bypass proxy entirely (local dev only)
DISABLE_PROXY=

# ── 2Captcha ──────────────────────────────────────────────────────────────────
# Solves reCAPTCHA V2 challenges during LinkedIn headless reconnect
TWOCAPTCHA_API_KEY=

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=LinkedReach <notifications@linkedreach.app>
APP_URL=https://linkedreach.pages.dev

# ── BrightData (optional alternative to residential proxy) ───────────────────
BRIGHTDATA_BROWSER_URL=
BRIGHTDATA_PROXY_URL=

# ── LinkedIn persistent Chrome profiles ───────────────────────────────────────
# Railway: mount a volume at /data/linkedin-profiles and set this path so
# Chrome profiles (and li_a tokens) survive redeployments.
LINKEDIN_PROFILES_DIR=/data/linkedin-profiles

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
PLAYWRIGHT_HEADLESS=true

# Supabase (backend)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Supabase (frontend — Vite)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Redis
REDIS_URL=redis://localhost:6379

# Claude API
ANTHROPIC_API_KEY=

# BrightData Scraping Browser (recommended for Railway/cloud deployments)
# BrightData runs Chromium on a residential IP — no CONNECT tunnel, no 403 from cloud servers.
# Get this from: brightdata.com → Proxies → your zone → Configuration → Browser API
# Format: wss://brd-customer-{CUSTOMER_ID}-zone-{ZONE_NAME}:{PASSWORD}@brd.superproxy.io:9222
BRIGHTDATA_BROWSER_URL=

# BrightData Residential Proxy (fallback for local dev / non-Railway environments)
# Format: http://brd-customer-{CUSTOMER_ID}-zone-{ZONE_NAME}:{PASSWORD}@brd.superproxy.io:22225
BRIGHTDATA_PROXY_URL=

# Set to 'true' to disable all proxies (local testing only)
DISABLE_PROXY=

# App
PORT=3001
NODE_ENV=development
